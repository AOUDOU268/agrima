{
  "info": {
    "_postman_id": "agrima-user-service",
    "name": "AGRIMA - Service Utilisateur",
    "description": "Collection complète de tests API pour le service utilisateur",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "1"
  },
  "item": [
    {
      "name": "Utilisateurs - GET ALL",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response is array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/utilisateurs",
          "host": ["{{base_url}}"],
          "path": ["api", "utilisateurs"]
        },
        "description": "Récupère la liste de tous les utilisateurs"
      },
      "response": []
    },
    {
      "name": "Utilisateurs - GET BY ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response has id, email, nom, prenom\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('email');",
              "    pm.expect(jsonData).to.have.property('nom');",
              "    pm.expect(jsonData).to.have.property('prenom');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/utilisateurs/1",
          "host": ["{{base_url}}"],
          "path": ["api", "utilisateurs", "1"]
        },
        "description": "Récupère un utilisateur par son ID"
      },
      "response": []
    },
    {
      "name": "Utilisateurs - POST (CREATE)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response has id\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.environment.set('user_id', jsonData.id);",
              "});",
              "pm.test(\"Email matches request\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.email).to.equal(pm.environment.get('test_email'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test.{{$timestamp}}@example.com\",\n  \"nom\": \"TestNom\",\n  \"prenom\": \"TestPrenom\",\n  \"telephone\": \"+33612345678\",\n  \"role\": \"USER\",\n  \"statut\": \"ACTIF\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/utilisateurs",
          "host": ["{{base_url}}"],
          "path": ["api", "utilisateurs"]
        },
        "description": "Crée un nouvel utilisateur"
      },
      "response": []
    },
    {
      "name": "Utilisateurs - POST (DUPLICATE EMAIL)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 409 Conflict\", function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "pm.test(\"Error message mentions email\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include('Email');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"duplicate@example.com\",\n  \"nom\": \"Duplicate\",\n  \"prenom\": \"User\",\n  \"telephone\": \"+33612345678\",\n  \"role\": \"USER\",\n  \"statut\": \"ACTIF\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/utilisateurs",
          "host": ["{{base_url}}"],
          "path": ["api", "utilisateurs"]
        },
        "description": "Test d'erreur: email déjà existant (409 Conflict)"
      },
      "response": []
    },
